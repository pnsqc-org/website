// Rename this file to wrangler.jsonc when developing locally.

{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "website",
  "pages_build_output_dir": "dist/",
  "compatibility_date": "2026-04-07",

  // Rebuild dist/ during local Pages dev whenever src/ changes.
  "build": {
    "command": "npm run build",
    "watch_dir": "src"
  }
}
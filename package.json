{
  "name": "website",
  "version": "1.0.0",
  "description": "Official website of the Pacific Northwest Software Quality Conference.",
  "main": "index.js",
  "scripts": {
    "build": "npm run build:dist && npm run build:css",
    "build:dist": "node build.mjs",
    "build:css": "npx @tailwindcss/cli -i src/css/input.css -o dist/css/site.css --minify",
    "audit:a11y": "node axe/run-a11y-audit.mjs",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "format": "prettier --check src/**/*.{html,js,css}",
    "format:write": "prettier --write src/**/*.{html,js,css}",
    "issues": "node skills/public/address-github-issue/scripts/github-issues.mjs",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pnsqc-org/website.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/pnsqc-org/website/issues"
  },
  "homepage": "https://github.com/pnsqc-org/website#readme",
  "dependencies": {
    "@tailwindcss/cli": "^4.2.2",
    "tailwindcss": "^4.2.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/js": "^10.0.1",
    "@html-eslint/eslint-plugin": "^0.58.1",
    "@html-eslint/parser": "^0.58.1",
    "axe-core": "^4.11.1",
    "eslint": "^10.1.0",
    "globals": "^17.4.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1"
  }
}

# Copy this file to `.env` and fill in real values.

# Used by skills/public/image-gen/scripts/image-gen/generate.mjs

GEMINI_API_KEY=your_gemini_api_key_here

# Used by skills/public/address-github-issue/scripts/github-issues.mjs

GITHUB_API_KEY=your_github_personal_access_token_here
GITHUB_REPOSITORY=owner/repo

# Used by .agents/skills/gmail-skill/gmail_skill.js (Node.js Gmail skill)

# Google Cloud OAuth Desktop App credentials

GMAIL_CLIENT_ID=your_google_oauth_client_id_here
GMAIL_CLIENT_SECRET=your_google_oauth_client_secret_here

# Managed automatically by the Gmail skill after OAuth login (base64-encoded JSON stores)

GMAIL_SKILL_TOKENS_B64=your_gmail_token_here
GMAIL_SKILL_ACCOUNTS_META_B64=your_skill_account_here

# Necessary for testing the Meetup API integration; only used locally (values are already set in Cloudflare Pages configuration)

MEETUP_CLIENT_ID=meetup_client_id_here
MEETUP_MEMBER_ID=meetup_member_id_here
MEETUP_SIGNING_KEY_ID=meetup_signing_key_id_here
MEETUP_SIGNING_KEY_PEM=meetup_signing_key_pem_here
MEETUP_GROUP_URLNAME=pnw-software-quality-professionals-pnsqc
RECENT_EVENTS_CACHE_TTL_SECONDS=120
MEETUP_LUMA_OVERRIDES_JSON={"312975891":"https://luma.com/9f10qhq7","313839680":"https://luma.com/7443v31u"}
